# ─── Адрес сайта / TLS ──────────────────────────────────────────────────────
# ":80"       → HTTP без сертификата (smoke-тест по IP, пока DNS не готов)
# "jcloko.ru" → боевой домен, авто-HTTPS (A-запись уже указывает на этот VPS)
SITE_ADDRESS=jcloko.ru

# Публичный URL сайта (используется Payload для ссылок/CORS/письма).
NEXT_PUBLIC_SERVER_URL=https://jcloko.ru

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=judo
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=judo
# host = имя сервиса из docker-compose (postgres)
DATABASE_URL=postgres://judo:replace_with_strong_password@postgres:5432/judo

# ─── Payload ────────────────────────────────────────────────────────────────
# Длинная случайная строка (openssl rand -hex 32). Смена ключа разлогинит всех.
PAYLOAD_SECRET=replace_with_long_random_secret

# ─── Сидинг первого администратора (срабатывает только на пустой БД) ────────
SEED_ADMIN_EMAIL=admin@jcloko.ru
SEED_ADMIN_PASSWORD=replace_with_strong_password
