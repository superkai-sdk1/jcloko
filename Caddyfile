# SITE_ADDRESS управляет режимом:
#   ":80"       — HTTP без TLS (для smoke-теста по IP, пока DNS не настроен)
#   "jcloko.ru" — боевой домен, авто-HTTPS через Let's Encrypt (A-запись уже на этот VPS)
# www — отдельный сайт-блок с постоянным редиректом на apex-домен: работает
# независимо от SITE_ADDRESS, при smoke-тесте по ":80" просто не выпустит
# сертификат и будет молча простаивать (не мешает основному блоку).
www.jcloko.ru {
	redir https://jcloko.ru{uri} permanent
}

{$SITE_ADDRESS} {
	encode zstd gzip

	# лимит на загрузку медиа
	request_body {
		max_size 25MB
	}

	reverse_proxy app:3000
}
